{% doc %}
  @prompt
    vytvoř sekci pro oddělovač
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-divider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
  }

  .ai-divider-line-{{ ai_gen_id }} {
    border: none;
    height: {{ block.settings.divider_thickness }}px;
    background-color: {{ block.settings.divider_color }};
    margin: 0;
    {% if block.settings.divider_style == 'dashed' %}
      background-image: repeating-linear-gradient(
        to right,
        {{ block.settings.divider_color }} 0px,
        {{ block.settings.divider_color }} {{ block.settings.dash_length }}px,
        transparent {{ block.settings.dash_length }}px,
        transparent {{ block.settings.dash_length | plus: block.settings.dash_gap }}px
      );
      background-color: transparent;
    {% elsif block.settings.divider_style == 'dotted' %}
      background-image: repeating-linear-gradient(
        to right,
        {{ block.settings.divider_color }} 0px,
        {{ block.settings.divider_color }} {{ block.settings.divider_thickness }}px,
        transparent {{ block.settings.divider_thickness }}px,
        transparent {{ block.settings.divider_thickness | times: 3 }}px
      );
      background-color: transparent;
    {% endif %}
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
  }

  @media screen and (max-width: 749px) {
    .ai-divider-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-divider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <hr class="ai-divider-line-{{ ai_gen_id }}">
</div>

{% schema %}
{
  "name": "Oddělovač",
  "settings": [
    {
      "type": "header",
      "content": "Styl"
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "Styl čáry",
      "options": [
        {
          "value": "solid",
          "label": "Plná"
        },
        {
          "value": "dashed",
          "label": "Čárkovaná"
        },
        {
          "value": "dotted",
          "label": "Tečkovaná"
        }
      ],
      "default": "solid"
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "label": "Tloušťka",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "dash_length",
      "label": "Délka čárky",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "dash_gap",
      "label": "Mezera mezi čárkami",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Barva",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "divider_opacity",
      "label": "Průhlednost",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 15
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Šířka na desktopu",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Oddělovač"
    }
  ]
}
{% endschema %}
