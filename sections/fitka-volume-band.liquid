{% comment %} sections/fitka-volume-band.liquid {% endcomment %}
<section
  class="fitka-volume"
  style="
    --bg: {{ section.settings.bg_color | default: '#f7f6f6' }};
    --pt: {{ section.settings.padding_top | default: 28 }}px;
    --pb: {{ section.settings.padding_bottom | default: 28 }}px;
  "
>
  <div class="page-width fitka-volume__wrap">
    <div class="fitka-volume__intro">
      <span class="fitka-volume__icon" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#a0304e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0l-7.2-7.2A2 2 0 0 1 2.8 12V4a1.2 1.2 0 0 1 1.2-1.2h8a2 2 0 0 1 1.4.6l7.2 7.2a2 2 0 0 1 0 2.8Z"></path><circle cx="7.5" cy="7.5" r="1.3"></circle></svg>
      </span>
      <div>
        {% if section.settings.heading != blank %}<h2 class="fitka-volume__h">{{ section.settings.heading }}</h2>{% endif %}
        {% if section.settings.note != blank %}<p class="fitka-volume__note">{{ section.settings.note }}</p>{% endif %}
      </div>
    </div>

    <div class="fitka-volume__tiers">
      {% for block in section.blocks %}
        <div class="fitka-volume__tier" {{ block.shopify_attributes }}>
          {% if block.settings.badge != blank %}<span class="fitka-volume__tag">{{ block.settings.badge }}</span>{% endif %}
          {% if block.settings.qty_label != blank %}<span class="fitka-volume__qty">{{ block.settings.qty_label }}</span>{% endif %}
          {% if block.settings.unit_price != blank %}<span class="fitka-volume__price">{{ block.settings.unit_price }}</span>{% endif %}
          {% if block.settings.save_text != blank %}<span class="fitka-volume__save">{{ block.settings.save_text }}</span>{% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="fitka-volume__cta">
        <a class="button button--primary" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      </div>
    {% endif %}
  </div>

  <style>
    .fitka-volume{ background:var(--bg); padding-top:var(--pt); padding-bottom:var(--pb); }
    .fitka-volume__wrap{ display:flex; flex-wrap:wrap; align-items:center; gap:24px; }
    .fitka-volume__intro{ display:flex; align-items:center; gap:14px; flex:1 1 260px; min-width:240px; }
    .fitka-volume__h{ font-size:clamp(20px,2.2vw,30px); margin:0 0 4px; line-height:1.1; }
    .fitka-volume__note{ font-size:.9rem; opacity:.75; margin:0; }

    .fitka-volume__tiers{ display:flex; flex-wrap:wrap; gap:12px; flex:2 1 420px; justify-content:flex-end; }
    .fitka-volume__tier{
      position:relative; flex:1 1 120px; min-width:110px; max-width:160px;
      background:#fff; border:1px solid #ece4e6; border-radius:14px;
      padding:18px 12px 14px; text-align:center;
      display:flex; flex-direction:column; gap:4px; align-items:center;
    }
    .fitka-volume__tag{
      position:absolute; top:-10px; left:50%; transform:translateX(-50%);
      background:#e65c2a; color:#fff; font-size:.66rem; font-weight:600;
      border-radius:999px; padding:3px 9px; white-space:nowrap;
    }
    .fitka-volume__qty{ font-weight:700; color:#393939; }
    .fitka-volume__price{ font-size:1.05rem; font-weight:700; color:#a0304e; }
    .fitka-volume__save{ font-size:.78rem; color:#393939; opacity:.7; }
    .fitka-volume__cta{ flex:1 1 100%; text-align:center; margin-top:6px; }

    @media (max-width:749px){
      .fitka-volume__tiers{ justify-content:center; }
      .fitka-volume__tier{ flex:1 1 44%; max-width:none; }
    }
  </style>
</section>

{% schema %}
{
  "name": "FitKa – Množstevní žebříček",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Čím víc kusů, tím výhodnější cena" },
    { "type": "text", "id": "note", "label": "Poznámka", "default": "Množstevní sleva se uplatní automaticky v košíku." },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f7f6f6" },
    { "type": "text", "id": "button_label", "label": "Text tlačítka (volitelné)" },
    { "type": "url", "id": "button_link", "label": "Odkaz tlačítka" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "default": 28, "label": "Padding top" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "default": 28, "label": "Padding bottom" }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Příčka",
      "settings": [
        { "type": "text", "id": "qty_label", "label": "Počet kusů", "default": "2 kusy" },
        { "type": "text", "id": "unit_price", "label": "Cena za kus", "default": "629 Kč / ks" },
        { "type": "text", "id": "save_text", "label": "Úspora", "default": "ušetříš 40 Kč" },
        { "type": "text", "id": "badge", "label": "Štítek (volitelné)", "info": "Např. Nejoblíbenější / Nejlepší cena" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "FitKa – Množstevní žebříček",
      "blocks": [
        { "type": "tier", "settings": { "qty_label": "1 kus", "unit_price": "649 Kč / ks", "save_text": "" } },
        { "type": "tier", "settings": { "qty_label": "2 kusy", "unit_price": "629 Kč / ks", "save_text": "ušetříš 40 Kč" } },
        { "type": "tier", "settings": { "qty_label": "3 kusy", "unit_price": "599 Kč / ks", "save_text": "ušetříš 150 Kč", "badge": "Nejoblíbenější" } },
        { "type": "tier", "settings": { "qty_label": "4+ kusy", "unit_price": "569 Kč / ks", "save_text": "ušetříš 320 Kč", "badge": "Nejlepší cena" } }
      ]
    }
  ]
}
{% endschema %}
