{% comment %} sections/fitka-footer.liquid {% endcomment %}
<footer
  class="fitka-footer"
  style="
    --bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --head: {{ section.settings.heading_color | default: '#393939' }};
    --text: {{ section.settings.text_color | default: '#6b6b6b' }};
    --hover: {{ section.settings.link_hover | default: '#a0304e' }};
    --pt: {{ section.settings.padding_top | default: 48 }}px;
    --pb: {{ section.settings.padding_bottom | default: 24 }}px;
  "
>
  <div class="page-width">
    <div class="fitka-footer__cols">
      {% for block in section.blocks %}
        {% case block.type %}

        {% when 'brand' %}
          <div class="fitka-footer__brand" {{ block.shopify_attributes }}>
            {% if block.settings.logo != blank %}
              {{ block.settings.logo | image_url: width: 360 | image_tag: class: 'fitka-footer__logo-img', alt: shop.name }}
            {% else %}
              <span class="fitka-footer__logo">Fit<svg class="fitka-footer__heart" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 20s-7-4.6-9.2-9C1.3 7.7 3 4.8 6 4.8c1.9 0 3.2 1.1 4 2.3.8-1.2 2.1-2.3 4-2.3 3 0 4.7 2.9 3.2 6.2C19 15.4 12 20 12 20Z"/></svg>Ka</span>
            {% endif %}
            {% if block.settings.tagline != blank %}<p class="fitka-footer__tag">{{ block.settings.tagline }}</p>{% endif %}
            {% if block.settings.show_socials %}
              <div class="fitka-footer__socials">
                {% if settings.social_instagram_link != blank %}
                  <a href="{{ settings.social_instagram_link }}" aria-label="Instagram"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg></a>
                {% endif %}
                {% if settings.social_facebook_link != blank %}
                  <a href="{{ settings.social_facebook_link }}" aria-label="Facebook"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 8.5h2V5.5h-2c-1.9 0-3 1.3-3 3v1.5H9v3h2V21h3v-7h2.2l.4-3H14v-1c0-.8.2-1.5 0-1.5Z"/></svg></a>
                {% endif %}
              </div>
            {% endif %}
          </div>

        {% when 'menu' %}
          <nav class="fitka-footer__menu" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}<h3>{{ block.settings.heading }}</h3>{% endif %}
            <ul>
              {% for link in linklists[block.settings.menu].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </nav>

        {% when 'contact' %}
          <div class="fitka-footer__contact" {{ block.shopify_attributes }}>
            {% if block.settings.email != blank %}<a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>{% endif %}
            {% if block.settings.phone != blank %}<a href="tel:{{ block.settings.phone | replace: ' ', '' }}">{{ block.settings.phone }}</a>{% endif %}
            {% if block.settings.hours != blank %}<span>{{ block.settings.hours }}</span>{% endif %}
            {% if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
              <div class="fitka-footer__pay">
                {% for type in shop.enabled_payment_types %}{{ type | payment_type_svg_tag: class: 'fitka-footer__pay-i' }}{% endfor %}
              </div>
            {% endif %}
          </div>

        {% endcase %}
      {% endfor %}
    </div>

    <div class="fitka-footer__bottom">
      {% if section.settings.copyright != blank %}
        {{ section.settings.copyright }}
      {% else %}
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Všechna práva vyhrazena.
      {% endif %}
    </div>
  </div>

  <style>
    .fitka-footer{ background:var(--bg); color:var(--text); padding:var(--pt) 0 0; }
    .fitka-footer__cols{ display:flex; flex-wrap:wrap; gap:32px 40px; padding-bottom:var(--pb); }
    .fitka-footer a{ color:inherit; text-decoration:none; transition:color .15s ease; }
    .fitka-footer a:hover{ color:var(--hover); }
    .fitka-footer h3{ color:var(--head); font-size:14px; font-weight:700; margin:0 0 14px; }

    .fitka-footer__brand{ flex:1 1 240px; min-width:200px; }
    .fitka-footer__logo{ display:inline-flex; align-items:center; gap:1px; font-size:26px; font-weight:700; color:var(--head); }
    .fitka-footer__heart{ color:var(--hover); margin:0 1px; }
    .fitka-footer__logo-img{ max-width:160px; height:auto; }
    .fitka-footer__tag{ margin:12px 0 16px; font-size:14px; }
    .fitka-footer__socials{ display:flex; gap:12px; }
    .fitka-footer__socials a{ width:38px; height:38px; border:1px solid #e6dde0; border-radius:50%; display:grid; place-items:center; color:var(--head); }
    .fitka-footer__socials a:hover{ border-color:var(--hover); }

    .fitka-footer__menu{ flex:0 1 170px; }
    .fitka-footer__menu ul{ list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px; }
    .fitka-footer__menu a{ font-size:14px; }

    .fitka-footer__contact{ flex:1 1 200px; margin-left:auto; display:flex; flex-direction:column; gap:8px; text-align:right; font-size:14px; }
    .fitka-footer__pay{ display:flex; gap:8px; justify-content:flex-end; margin-top:14px; flex-wrap:wrap; }
    .fitka-footer__pay-i{ width:38px; height:24px; }

    .fitka-footer__bottom{ border-top:1px solid #ece4e6; padding:18px 0; text-align:center; font-size:13px; opacity:.8; }

    @media (max-width:749px){
      .fitka-footer__cols{ gap:28px; }
      .fitka-footer__brand, .fitka-footer__menu, .fitka-footer__contact{ flex:1 1 100%; margin-left:0; text-align:left; }
      .fitka-footer__pay{ justify-content:flex-start; }
    }
  </style>
</footer>

{% schema %}
{
  "name": "FitKa – Footer",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Pozadí", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Barva nadpisů / loga", "default": "#393939" },
    { "type": "color", "id": "text_color", "label": "Barva textu", "default": "#6b6b6b" },
    { "type": "color", "id": "link_hover", "label": "Barva hover / akcent", "default": "#a0304e" },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Zobrazit platební ikony", "default": true },
    { "type": "text", "id": "copyright", "label": "Copyright (prázdné = auto rok + název obchodu)" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 48, "label": "Padding nahoře" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 24, "label": "Padding dole" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Značka (logo + sociálky)",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo (volitelné – jinak text Fit♥Ka)" },
        { "type": "text", "id": "tagline", "label": "Tagline", "default": "První vrstva, která tě podrží." },
        { "type": "checkbox", "id": "show_socials", "label": "Zobrazit sociální sítě", "default": true }
      ]
    },
    {
      "type": "menu",
      "name": "Sloupec s menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Nadpis sloupce", "default": "Nakupuj" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "contact",
      "name": "Kontakt + platby",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "email", "label": "E-mail", "default": "info@fitka.cz" },
        { "type": "text", "id": "phone", "label": "Telefon", "default": "+420 777 123 456" },
        { "type": "text", "id": "hours", "label": "Otevírací doba", "default": "Po–Pá 9:00 – 16:00" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FitKa – Footer",
      "blocks": [
        { "type": "brand" },
        { "type": "menu", "settings": { "heading": "Nakupuj" } },
        { "type": "menu", "settings": { "heading": "Informace" } },
        { "type": "menu", "settings": { "heading": "Zákaznická péče" } },
        { "type": "contact" }
      ]
    }
  ]
}
{% endschema %}