{% comment %} sections/fitka-cut-tiles.liquid {% endcomment %}
<section
  class="fitka-cuts"
  style="
    --bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --pt: {{ section.settings.padding_top | default: 28 }}px;
    --pb: {{ section.settings.padding_bottom | default: 28 }}px;
  "
>
  <div class="page-width fitka-cuts__wrap">
    {% if section.settings.heading != blank %}
      <h2 class="fitka-cuts__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="fitka-cuts__sub">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="fitka-cuts__grid">
      {% for block in section.blocks %}
        {% case block.type %}

        {% when 'tile' %}
          {%- assign product = block.settings.product -%}
          <article class="fitka-cut" {{ block.shopify_attributes }}>
            <a class="fitka-cut__media" href="{{ product.url | default: '#' }}">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'fitka-cut__img' }}
              {%- elsif product.featured_image -%}
                {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'fitka-cut__img' }}
              {%- endif -%}
              {% if product.compare_at_price_max > product.price %}
                <span class="fitka-cut__badge">Sleva</span>
              {% endif %}
            </a>

            <div class="fitka-cut__body">
              {% if product != blank %}
                <a class="fitka-cut__name" href="{{ product.url }}">{{ product.title }}</a>
              {% else %}
                <span class="fitka-cut__name">Vyber produkt</span>
              {% endif %}

              {%- assign desc = block.settings.description | default: product.metafields.fitka.short_desc -%}
              {% if desc != blank %}
                <p class="fitka-cut__desc">{{ desc }}</p>
              {% endif %}

              {% if product != blank %}
                <div class="fitka-cut__price">{% render 'price', product: product %}</div>
                <a class="button button--primary fitka-cut__btn" href="{{ product.url }}">
                  {{ block.settings.button_label | default: 'Zobrazit' }}
                </a>
              {% endif %}
            </div>

            {%- assign has_chips = false -%}
            {% if block.settings.chip_1 != blank or block.settings.chip_2 != blank or block.settings.chip_3 != blank %}{% assign has_chips = true %}{% endif %}
            {% if has_chips %}
              <ul class="fitka-cut__chips">
                {% if block.settings.chip_1 != blank %}<li>{{ block.settings.chip_1 }}</li>{% endif %}
                {% if block.settings.chip_2 != blank %}<li>{{ block.settings.chip_2 }}</li>{% endif %}
                {% if block.settings.chip_3 != blank %}<li>{{ block.settings.chip_3 }}</li>{% endif %}
              </ul>
            {% endif %}
          </article>

        {% when 'helper' %}
          <aside class="fitka-cut__helper" {{ block.shopify_attributes }}>
            <span class="fitka-cut__helper-icon" aria-hidden="true">
              <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.2-3.2"></path><path d="M11 8.2c.9-1.3 3-1 3 .6 0 1.2-1.3 1.4-1.5 2.2"></path></svg>
            </span>
            {% if block.settings.heading != blank %}<h3 class="fitka-cut__helper-h">{{ block.settings.heading }}</h3>{% endif %}
            {% if block.settings.text != blank %}<p class="fitka-cut__helper-t">{{ block.settings.text }}</p>{% endif %}
            <ul class="fitka-cut__checks">
              {% if block.settings.check_1 != blank %}<li>{{ block.settings.check_1 }}</li>{% endif %}
              {% if block.settings.check_2 != blank %}<li>{{ block.settings.check_2 }}</li>{% endif %}
              {% if block.settings.check_3 != blank %}<li>{{ block.settings.check_3 }}</li>{% endif %}
            </ul>
            {% if block.settings.button_label != blank %}
              <a class="button button--primary" href="{{ block.settings.button_link | default: '#' }}">{{ block.settings.button_label }}</a>
            {% endif %}
          </aside>

        {% endcase %}
      {% endfor %}
    </div>
  </div>

  <style>
    .fitka-cuts{ background:var(--bg); padding-top:var(--pt); padding-bottom:var(--pb); }
    .fitka-cuts__heading{ text-align:center; font-size:clamp(26px,3vw,40px); margin:0 0 6px; }
    .fitka-cuts__sub{ text-align:center; opacity:.8; margin:0 auto 26px; max-width:52ch; }

    .fitka-cuts__grid{ display:flex; flex-wrap:wrap; gap:20px; align-items:stretch; justify-content:center; }

    /* ----- product tile ----- */
    .fitka-cut{
      flex:1 1 320px; min-width:280px; max-width:460px;
      background:#fff; border:1px solid #efe7e9; border-radius:18px; overflow:hidden;
      display:flex; flex-direction:column;
    }
    .fitka-cut__media{ position:relative; display:block; aspect-ratio:4/5; background:#f4eef0; }
    .fitka-cut__img{ width:100%; height:100%; object-fit:cover; display:block; }
    .fitka-cut__badge{ position:absolute; top:12px; left:12px; background:#a0304e; color:#fff; border-radius:999px; font-size:.72rem; padding:4px 10px; }
    .fitka-cut__body{ padding:18px 18px 6px; display:flex; flex-direction:column; gap:8px; flex:1; }
    .fitka-cut__name{ font-size:1.25rem; font-weight:700; color:#393939; text-decoration:none; }
    .fitka-cut__desc{ font-size:.95rem; opacity:.82; margin:0; }
    .fitka-cut__price{ font-size:1.25rem; font-weight:700; color:#393939; margin-top:auto; }
    .fitka-cut__btn{ align-self:flex-start; margin-top:4px; }
    .fitka-cut__chips{ list-style:none; display:flex; flex-wrap:wrap; gap:8px; margin:0; padding:14px 18px 20px; }
    .fitka-cut__chips li{ font-size:.78rem; background:#f7f6f6; color:#393939; border-radius:999px; padding:6px 12px; line-height:1; }

    /* ----- helper card ----- */
    .fitka-cut__helper{
      flex:1 1 260px; min-width:240px; max-width:340px;
      background:#ffe2e3; border-radius:18px; padding:26px 22px;
      display:flex; flex-direction:column; gap:10px; text-align:left;
    }
    .fitka-cut__helper-icon{ color:#a0304e; }
    .fitka-cut__helper-h{ font-size:1.3rem; margin:0; color:#393939; }
    .fitka-cut__helper-t{ font-size:.95rem; opacity:.85; margin:0; }
    .fitka-cut__checks{ list-style:none; margin:6px 0 4px; padding:0; display:flex; flex-direction:column; gap:8px; }
    .fitka-cut__checks li{ position:relative; padding-left:24px; font-size:.92rem; color:#393939; }
    .fitka-cut__checks li::before{ content:"✓"; position:absolute; left:0; top:0; color:#a0304e; font-weight:700; }
    .fitka-cut__helper .button{ margin-top:auto; }

    @media (max-width:749px){
      .fitka-cut, .fitka-cut__helper{ flex:1 1 100%; max-width:none; }
    }
  </style>
</section>

{% schema %}
{
  "name": "FitKa – Vyber střih",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Vyber si svůj střih" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Každý střih má své výhody. Vyber ten, který sedí nejvíc tobě." },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "default": 28, "label": "Padding top" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "default": 28, "label": "Padding bottom" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Dlaždice střihu",
      "settings": [
        { "type": "product", "id": "product", "label": "Produkt" },
        { "type": "image_picker", "id": "image", "label": "Obrázek (volitelné – jinak hlavní foto produktu)" },
        { "type": "text", "id": "description", "label": "Popisek", "info": "Prázdné = metafield fitka.short_desc" },
        { "type": "text", "id": "button_label", "label": "Text tlačítka", "default": "Zobrazit" },
        { "type": "header", "content": "Chips (volitelné)" },
        { "type": "text", "id": "chip_1", "label": "Chip 1" },
        { "type": "text", "id": "chip_2", "label": "Chip 2" },
        { "type": "text", "id": "chip_3", "label": "Chip 3" }
      ]
    },
    {
      "type": "helper",
      "name": "Karta – pomoc s výběrem",
      "settings": [
        { "type": "text", "id": "heading", "label": "Nadpis", "default": "Neviš, který střih?" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Každé tělo je jiné. Rády ti pomůžeme vybrat ten pravý." },
        { "type": "text", "id": "check_1", "label": "Odrážka 1", "default": "Jen 30 sekund" },
        { "type": "text", "id": "check_2", "label": "Odrážka 2", "default": "Doporučení na míru" },
        { "type": "text", "id": "check_3", "label": "Odrážka 3", "default": "Bez přemýšlení" },
        { "type": "text", "id": "button_label", "label": "Text tlačítka", "default": "Pomůžeme ti vybrat" },
        { "type": "url", "id": "button_link", "label": "Odkaz tlačítka" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FitKa – Vyber střih",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "helper" }
      ]
    }
  ]
}
{% endschema %}
