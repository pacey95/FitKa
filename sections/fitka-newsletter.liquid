{% comment %} sections/fitka-newsletter.liquid {% endcomment %}
<section
  class="fitka-news"
  style="
    --bg: {{ section.settings.bg_color | default: '#a0304e' }};
    --text: {{ section.settings.text_color | default: '#ffffff' }};
    --pt: {{ section.settings.padding_top | default: 16 }}px;
    --pb: {{ section.settings.padding_bottom | default: 16 }}px;
  "
>
  <div class="page-width">
    <div class="fitka-news__band">
      <div class="fitka-news__intro">
        <span class="fitka-news__ic" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg>
        </span>
        <div class="fitka-news__txt">
          {% if section.settings.title != blank %}<strong>{{ section.settings.title }}</strong>{% endif %}
          {% if section.settings.subtitle != blank %}<span>{{ section.settings.subtitle }}</span>{% endif %}
        </div>
      </div>

      <div class="fitka-news__form">
        {%- form 'customer', class: 'fitka-news__formel' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p class="fitka-news__ok">Hotovo! Brzy se ozveme. 💌</p>
          {%- else -%}
            <div class="fitka-news__row">
              <input type="email" name="contact[email]" required
                placeholder="{{ section.settings.placeholder | default: 'Váš e-mail' }}"
                aria-label="{{ section.settings.placeholder | default: 'Váš e-mail' }}">
              <button type="submit">{{ section.settings.button_label | default: 'Chci být v obraze' }}</button>
            </div>
            {%- if form.errors -%}
              <small class="fitka-news__err">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</small>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}
      </div>

      <div class="fitka-news__perks">
        {% if section.settings.perk_1 != blank %}
          <span class="fitka-news__perk"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>{{ section.settings.perk_1 }}</span>
        {% endif %}
        {% if section.settings.perk_2 != blank %}
          <span class="fitka-news__perk"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>{{ section.settings.perk_2 }}</span>
        {% endif %}
      </div>
    </div>
  </div>

  <style>
    .fitka-news{ padding:var(--pt) 0 var(--pb); }
    .fitka-news__band{
      background:var(--bg); color:var(--text); border-radius:18px;
      padding:clamp(18px,2.6vw,28px) clamp(22px,4vw,46px);
      display:grid; grid-template-columns:1fr 1.25fr 1fr; align-items:center; gap:clamp(20px,3.5vw,44px);
    }
    .fitka-news__intro{ display:flex; align-items:center; gap:16px; }
    .fitka-news__ic{ width:50px; height:50px; flex:0 0 auto; border:1.5px solid rgba(255,255,255,.55); border-radius:12px; display:grid; place-items:center; }
    .fitka-news__txt{ display:flex; flex-direction:column; line-height:1.35; }
    .fitka-news__txt strong{ font-weight:700; }
    .fitka-news__txt span{ opacity:.92; }

    .fitka-news__row{ display:flex; align-items:center; background:#fff; border-radius:999px; padding:6px; gap:6px; }
    .fitka-news__row input{ flex:1 1 auto; min-width:0; border:0; background:transparent; padding:10px 18px; font-size:15px; color:#393939; }
    .fitka-news__row input:focus{ outline:none; }
    .fitka-news__row button{
      flex:0 0 auto; border:1px solid rgba(255,255,255,.6); background:var(--bg); color:#fff;
      border-radius:999px; padding:12px 22px; font-size:14px; font-weight:600; white-space:nowrap; cursor:pointer;
      transition:filter .15s ease;
    }
    .fitka-news__row button:hover{ filter:brightness(1.12); }
    .fitka-news__ok{ margin:0; font-weight:600; }
    .fitka-news__err{ display:block; margin-top:8px; opacity:.95; }

    .fitka-news__perks{ display:flex; flex-direction:column; gap:12px; border-left:1px solid rgba(255,255,255,.3); padding-left:clamp(20px,3vw,40px); }
    .fitka-news__perk{ display:flex; align-items:center; gap:10px; font-size:15px; }

    @media (max-width:990px){
      .fitka-news__band{ grid-template-columns:1fr; gap:22px; text-align:center; }
      .fitka-news__intro{ justify-content:center; }
      .fitka-news__perks{ border-left:0; padding-left:0; align-items:center; }
    }
    @media (max-width:600px){
      .fitka-news__row{ flex-direction:column; border-radius:16px; padding:8px; }
      .fitka-news__row input{ width:100%; text-align:center; }
      .fitka-news__row button{ width:100%; }
    }
  </style>
</section>

{% schema %}
{
  "name": "FitKa – Newsletter",
  "settings": [
    { "type": "header", "content": "Vzhled" },
    { "type": "color", "id": "bg_color", "label": "Pozadí pruhu", "default": "#a0304e" },
    { "type": "color", "id": "text_color", "label": "Barva textu", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 60, "step": 2, "default": 16, "label": "Padding nahoře" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 60, "step": 2, "default": 16, "label": "Padding dole" },
    { "type": "header", "content": "Obsah" },
    { "type": "text", "id": "title", "label": "Nadpis", "default": "Buď první, kdo se dozví novinky" },
    { "type": "text", "id": "subtitle", "label": "Podnadpis", "default": "a získá tipy pro pohodlí i výkon." },
    { "type": "text", "id": "placeholder", "label": "Placeholder pole", "default": "Váš e-mail" },
    { "type": "text", "id": "button_label", "label": "Text tlačítka", "default": "Chci být v obraze" },
    { "type": "header", "content": "Výhody (pravý sloupec)" },
    { "type": "text", "id": "perk_1", "label": "Výhoda 1", "default": "Sleva 10 % na první nákup" },
    { "type": "text", "id": "perk_2", "label": "Výhoda 2", "default": "Žádný spam, jen to důležité" }
  ],
  "presets": [{ "name": "FitKa – Newsletter" }]
}
{% endschema %}