{% comment %} sections/fitka-pdp-info.liquid {% endcomment %}

{%- liquid
  assign benefits = section.blocks | where: 'type', 'benefit'
  assign trust = section.blocks | where: 'type', 'trust'
-%}

<section
  class="fpi"
  style="
    --bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --pt: {{ section.settings.padding_top | default: 28 }}px;
    --pb: {{ section.settings.padding_bottom | default: 28 }}px;
    --fpi-text-size: {{ section.settings.text_size | default: 15 }}px;
    --fpi-icon-size: {{ section.settings.icon_size | default: 28 }}px;
    --fpi-helper-icon-size: {{ section.settings.helper_icon_size | default: 46 }}px;
    --fpi-icon-stroke: {{ section.settings.icon_stroke | default: 1.6 }};
  "
>
  <div class="page-width fpi__grid">

    <div class="fpi__col">
      {% if section.settings.left_heading != blank %}
        <h3 class="fpi__h">{{ section.settings.left_heading }}</h3>
      {% endif %}

      <ul class="fpi__list">
        {%- for block in benefits -%}
          <li class="fpi__item" {{ block.shopify_attributes }}>
            <span class="fpi__ic" aria-hidden="true">
              {%- if block.settings.custom_icon != blank -%}
                {{
                  block.settings.custom_icon
                  | image_url: width: 120
                  | image_tag:
                    class: 'fpi__icon-img',
                    loading: 'lazy',
                    alt: ''
                }}
              {%- else -%}
                {%- render 'fitka-feature-icon', icon: block.settings.icon -%}
              {%- endif -%}
            </span>

            <span class="fpi__txt">
              <strong>{{ block.settings.title }}</strong>
              {% if block.settings.subtitle != blank %}
                <span>{{ block.settings.subtitle }}</span>
              {% endif %}
            </span>
          </li>
        {%- endfor -%}
      </ul>

     <div class="fpi__helper-head">
        <span class="fpi__tape" aria-hidden="true">
          {%- if section.settings.helper_icon != blank -%}
            {{
              section.settings.helper_icon
              | image_url: width: 160
              | image_tag:
                class: 'fpi__helper-icon-img',
                loading: 'lazy',
                alt: ''
            }}
          {%- else -%}
            <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="#a0304e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="7"/>
              <path d="m20 20-3.5-3.5"/>
            </svg>
          {%- endif -%}
        </span>

        {% if section.settings.helper_heading != blank %}
          <h3 class="fpi__helper-h">{{ section.settings.helper_heading }}</h3>
        {% endif %}
      </div>

      {% if section.settings.helper_text != blank %}
        <p class="fpi__helper-t">{{ section.settings.helper_text }}</p>
      {% endif %}

      {% if section.settings.helper_button_label != blank %}
        <a class="button button--primary fpi__helper-btn" href="{{ section.settings.helper_button_link | default: '#' }}">
          {{ section.settings.helper_button_label }}
        </a>
      {% endif %}

      {% if section.settings.helper_subtext != blank %}
        <p class="fpi__helper-sub">{{ section.settings.helper_subtext }}</p>
      {% endif %}
    </div>

    <div class="fpi__col">
      <ul class="fpi__list">
        {%- for block in trust -%}
          <li class="fpi__item" {{ block.shopify_attributes }}>
            <span class="fpi__ic" aria-hidden="true">
              {%- if block.settings.custom_icon != blank -%}
                {{
                  block.settings.custom_icon
                  | image_url: width: 120
                  | image_tag:
                    class: 'fpi__icon-img',
                    loading: 'lazy',
                    alt: ''
                }}
              {%- else -%}
                {%- render 'fitka-feature-icon', icon: block.settings.icon -%}
              {%- endif -%}
            </span>

            <span class="fpi__txt">
              <strong>{{ block.settings.title }}</strong>
              {% if block.settings.subtitle != blank %}
                <span>{{ block.settings.subtitle }}</span>
              {% endif %}
            </span>
          </li>
        {%- endfor -%}
      </ul>
    </div>

  </div>

  <style>
    .fpi {
      background: var(--bg);
      padding-top: var(--pt);
      padding-bottom: var(--pb);
    }

    .fpi__grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 24px;
      align-items: stretch;
    }

    .fpi__h {
      font-size: 1.8rem;
      line-height: 1.3;
      margin: 0 0 16px;
      color: #393939;
    }

    .fpi__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .fpi__item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }

    .fpi__ic {
      flex: 0 0 auto;
      width: var(--fpi-icon-size);
      height: var(--fpi-icon-size);
      color: #a0304e;
      margin-top: 1px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .fpi__ic svg,
    .fpi__icon-img {
      width: var(--fpi-icon-size);
      height: var(--fpi-icon-size);
      display: block;
    }
    .fpi__ic svg *{ stroke-width: var(--fpi-icon-stroke, 1.6); }

    .fpi__icon-img {
      object-fit: contain;
    }

    .fpi__txt {
      display: flex;
      flex-direction: column;
      line-height: 1.4;
      font-size: var(--fpi-text-size);
      color: #393939;
    }

    .fpi__txt strong {
      color: #393939;
      font-size: inherit;
      font-weight: 600;
    }

    .fpi__txt span {
      color: #393939;
      opacity: .7;
      font-size: inherit;
    }

    .fpi__helper {
      background: #ffe2e3;
      border-radius: 16px;
      padding: 26px 22px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: center;
      text-align: center;
      position: relative;
    }

    .fpi__helper-head {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .fpi__tape {
      margin-bottom: 0;
      width: var(--fpi-helper-icon-size);
      height: var(--fpi-helper-icon-size);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #a0304e;
    }

    .fpi__tape svg,
    .fpi__helper-icon-img {
      width: var(--fpi-helper-icon-size);
      height: var(--fpi-helper-icon-size);
      display: block;
    }

    .fpi__helper-icon-img {
      object-fit: contain;
    }

    .fpi__helper-h {
      font-size: 1.8rem;
      line-height: 1.3;
      margin: 0;
      color: #393939;
    }

    .fpi__helper-t {
      margin: 0;
      color: #393939;
      opacity: .85;
      font-size: var(--fpi-text-size);
      line-height: 1.4;
    }

    .fpi__helper-btn {
      margin: 8px 0 4px;
    }

    .fpi__helper-sub {
      margin: 0;
      color: #393939;
      opacity: .65;
      font-size: var(--fpi-text-size);
      line-height: 1.4;
    }

    @media (max-width: 989px) {
      .fpi__grid {
        grid-template-columns: 1fr;
      }

      .fpi__helper {
        order: -1;
      }
    }
  </style>
</section>

{% schema %}
{
