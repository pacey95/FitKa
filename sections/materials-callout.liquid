{% comment %} sections/materials-callout.liquid {% endcomment %}
<section class="fitka-materials page-width">
  <div class="fitka-materials__grid">
    <div class="fitka-materials__content">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <a href="{{ section.settings.link_url }}" class="button button--secondary">{{ section.settings.link_label }}</a>
      {% endif %}
    </div>
    <div class="fitka-materials__media">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'fitka-materials__image' }}
      {% endif %}
    </div>
  </div>

  <ul class="fitka-materials__bullets">
    {% for block in section.blocks %}
      <li class="fitka-materials__bullet">
        {% if block.settings.icon != blank %}
          {{ block.settings.icon | image_url: width: 32 | image_tag: class: 'fitka-materials__icon', alt: block.settings.title }}
        {% endif %}
        <div>
          <strong>{{ block.settings.title }}</strong>
          <div class="fitka-materials__small">{{ block.settings.desc }}</div>
        </div>
      </li>
    {% endfor %}
  </ul>

  <style>
    .fitka-materials{padding:36px 0}
    .fitka-materials__grid{display:grid;grid-template-columns:1.2fr .8fr;gap:28px;align-items:center}
    @media(max-width:900px){.fitka-materials__grid{grid-template-columns:1fr}}
    .fitka-materials__image{width:100%;border-radius:16px}
    .fitka-materials__bullets{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:18px;list-style:none;padding:0}
    @media(max-width:900px){.fitka-materials__bullets{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:580px){.fitka-materials__bullets{grid-template-columns:1fr}}
    .fitka-materials__bullet{display:flex;gap:12px;align-items:flex-start;border:1px solid #eee;border-radius:14px;padding:12px}
    .fitka-materials__icon{width:24px;height:24px;object-fit:contain}
    .fitka-materials__small{font-size:.95rem;opacity:.9}
  </style>
</section>

{% schema %}
{
  "name": "Materiály & technologie",
  "settings": [
    { "type": "text", "id": "heading", "label": "Nadpis", "default": "Výkonné materiály, které dýchají" },
    { "type": "textarea", "id": "text", "label": "Popis", "default": "Antibakteriální úprava, rychleschnoucí vlákna a bezšvová konstrukce pro maximální pohodlí při pohybu." },
    { "type": "image_picker", "id": "image", "label": "Obrázek" },
    { "type": "text", "id": "link_label", "label": "Tlačítko – text", "default": "Zjistit víc" },
    { "type": "url", "id": "link_url", "label": "Tlačítko – odkaz" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Ikona" },
        { "type": "text", "id": "title", "label": "Titulek", "default": "Antibakteriální" },
        { "type": "text", "id": "desc", "label": "Popis", "default": "Pocit svěžesti po celý den." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Materiály & technologie", "category": "FitKa" }]
}
{% endschema %}
