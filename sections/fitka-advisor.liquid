{% comment %} sections/fitka-cut-advisor.liquid — modal rádce: střih + velikost {% endcomment %}
{%- assign tp = section.settings.tanga_product -%}
{%- assign bp = section.settings.brief_product -%}
<div
  class="fca-modal"
  id="fitka-advisor"
  aria-hidden="true"
  data-tiebreak="{{ section.settings.tiebreak_default | default: 'brief' }}"
  data-sizes='{
    "brief": { "S": [{{ section.settings.b_s_min | default: 62 }},{{ section.settings.b_s_max | default: 68 }}], "M": [{{ section.settings.b_m_min | default: 64 }},{{ section.settings.b_m_max | default: 72 }}], "L": [{{ section.settings.b_l_min | default: 66 }},{{ section.settings.b_l_max | default: 76 }}] },
    "tanga": { "S": [{{ section.settings.t_s_min | default: 64 }},{{ section.settings.t_s_max | default: 70 }}], "M": [{{ section.settings.t_m_min | default: 66 }},{{ section.settings.t_m_max | default: 76 }}], "L": [{{ section.settings.t_l_min | default: 70 }},{{ section.settings.t_l_max | default: 80 }}] }
  }'
>
  <div class="fca-overlay" data-fca-close></div>
  <div class="fca-dialog" role="dialog" aria-modal="true" aria-label="Rádce výběru">
    <button class="fca-close" data-fca-close aria-label="Zavřít">&times;</button>

    <div class="fca-head">
      <h2>{{ section.settings.heading | default: 'Poradíme ti s výběrem' }}</h2>
      <p class="fca-intro">{{ section.settings.intro | default: 'Zabere to jen pár sekund.' }}</p>
      <div class="fca-dots" aria-hidden="true" hidden></div>
    </div>

    <!-- VSTUPNÍ VOLBA -->
    <div class="fca-entry">
      <button type="button" class="fca-opt fca-opt--big" data-mode="cut">
        <strong>{{ section.settings.entry_cut | default: 'Pomoz mi vybrat střih' }}</strong>
        <span>Tanga, nebo Brief? 3 rychlé otázky.</span>
      </button>
      <button type="button" class="fca-opt fca-opt--big" data-mode="size">
        <strong>{{ section.settings.entry_size | default: 'Pomoz mi vybrat velikost' }}</strong>
        <span>Podle tvé míry a tabulky velikostí.</span>
      </button>
    </div>

    <!-- KVÍZ STŘIHU -->
    <div class="fca-steps" hidden>
      {% for block in section.blocks %}
        {% if block.type == 'question' %}
          <div class="fca-step" data-step="{{ forloop.index0 }}" hidden {{ block.shopify_attributes }}>
            <h3 class="fca-q">{{ block.settings.question }}</h3>
            <div class="fca-opts">
              {% for i in (1..4) %}
                {%- assign key_lbl = 'option_' | append: i | append: '_label' -%}
                {%- assign key_tgt = 'option_' | append: i | append: '_target' -%}
                {%- assign lbl = block.settings[key_lbl] -%}
                {%- assign tgt = block.settings[key_tgt] -%}
                {% if lbl != blank %}
                  <button type="button" class="fca-opt" data-target="{{ tgt | default: 'tanga' }}">{{ lbl }}</button>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- VÝSLEDKY STŘIHU -->
    <div class="fca-result" data-result="tanga" hidden>
      <p class="fca-recap"></p>
      <span class="fca-badge">Náš tip pro tebe</span>
      <h3>{{ tp.title | default: 'Tanga FitKa' }}</h3>
      <ul class="fca-reasons">
        {% if section.settings.tanga_r1 != blank %}<li>{{ section.settings.tanga_r1 }}</li>{% endif %}
        {% if section.settings.tanga_r2 != blank %}<li>{{ section.settings.tanga_r2 }}</li>{% endif %}
        {% if section.settings.tanga_r3 != blank %}<li>{{ section.settings.tanga_r3 }}</li>{% endif %}
      </ul>
      {% if section.settings.tanga_tagline != blank %}<p class="fca-tagline">{{ section.settings.tanga_tagline }}</p>{% endif %}
      {% if tp %}<div class="fca-price">{{ tp.price | money }}</div>{% endif %}
      <a class="button button--primary" href="{{ tp.url | default: '/products/brazilky-fitka' }}">Zobrazit Tanga</a>
      <button type="button" class="fca-next" data-size-for="tanga">Pokračovat na výběr velikosti →</button>
      <button type="button" class="fca-other" data-show="brief">Nebo mrkni na Brief</button>
      {% if section.settings.article_url != blank %}<a class="fca-more" href="{{ section.settings.article_url }}">Chci vědět víc o výběru</a>{% endif %}
      <button type="button" class="fca-restart" data-fca-restart>Začít znovu</button>
    </div>

    <div class="fca-result" data-result="brief" hidden>
      <p class="fca-recap"></p>
      <span class="fca-badge">Náš tip pro tebe</span>
      <h3>{{ bp.title | default: 'Brief FitKa' }}</h3>
      <ul class="fca-reasons">
        {% if section.settings.brief_r1 != blank %}<li>{{ section.settings.brief_r1 }}</li>{% endif %}
        {% if section.settings.brief_r2 != blank %}<li>{{ section.settings.brief_r2 }}</li>{% endif %}
        {% if section.settings.brief_r3 != blank %}<li>{{ section.settings.brief_r3 }}</li>{% endif %}
      </ul>
      {% if section.settings.brief_tagline != blank %}<p class="fca-tagline">{{ section.settings.brief_tagline }}</p>{% endif %}
      {% if bp %}<div class="fca-price">{{ bp.price | money }}</div>{% endif %}
      <a class="button button--primary" href="{{ bp.url | default: '/products/brief-fitka' }}">Zobrazit Brief</a>
      <button type="button" class="fca-next" data-size-for="brief">Pokračovat na výběr velikosti →</button>
      <button type="button" class="fca-other" data-show="tanga">Nebo mrkni na Tanga</button>
      {% if section.settings.article_url != blank %}<a class="fca-more" href="{{ section.settings.article_url }}">Chci vědět víc o výběru</a>{% endif %}
      <button type="button" class="fca-restart" data-fca-restart>Začít znovu</button>
    </div>

    <!-- PORADCE VELIKOSTI: krok 1 – střih -->
    <div class="fca-sizecut" hidden>
      <h3 class="fca-q">Pro který střih vybíráš velikost?</h3>
      <div class="fca-opts">
        <button type="button" class="fca-opt" data-sizecut="brief">Brief</button>
        <button type="button" class="fca-opt" data-sizecut="tanga">Tanga</button>
      </div>
    </div>

    <!-- PORADCE VELIKOSTI: krok 2 – míra -->
    <div class="fca-measure" hidden>
      <h3 class="fca-q">{{ section.settings.measure_q | default: 'Jaký máš obvod v místě, kde kalhotky nosíš?' }}</h3>
      <p class="fca-hint">{{ section.settings.measure_hint | default: 'Změř se krejčovským metrem přes boky v místě, kde ti sedí lem kalhotek – volně, bez zatahování.' }}{% if section.settings.size_table_url != blank %} <a class="fca-tablelink" href="{{ section.settings.size_table_url }}">Tabulka velikostí</a>{% endif %}</p>
      <div class="fca-input">
        <input type="number" inputmode="decimal" min="40" max="130" step="0.5" placeholder="např. 68" aria-label="Obvod v cm">
        <span>cm</span>
      </div>
      <button type="button" class="button button--primary fca-calc" disabled>Doporučit velikost</button>
    </div>

    <!-- PORADCE VELIKOSTI: krok 3 – preferovaný pocit -->
    <div class="fca-feel" hidden>
      <h3 class="fca-q">Jaký pocit na těle preferuješ?</h3>
      <div class="fca-opts">
        <button type="button" class="fca-opt" data-feel="tight">Pevnější – ať pěkně drží</button>
        <button type="button" class="fca-opt" data-feel="balanced">Vyvážený</button>
        <button type="button" class="fca-opt" data-feel="loose">Volnější – hlavně ať nikde netlačí</button>
      </div>
    </div>

    <!-- PORADCE VELIKOSTI: výsledek -->
    <div class="fca-sizeresult" hidden>
      <p class="fca-recap fca-recap--size"></p>
      <span class="fca-badge">Doporučená velikost</span>
      <div class="fca-sizeletter" aria-live="polite">M</div>
      <p class="fca-sizematch"></p>
      <p class="fca-sizefeel"></p>
      <div class="fca-sizealts"></div>
      <p class="fca-sizenote">
        <span>{{ section.settings.size_disclaimer | default: 'Není to 100% záruka – pokud velikost nesedne, vyměníme ti ji.' }}</span>
        {% if section.settings.size_table_url != blank %}<a class="fca-tablelink" href="{{ section.settings.size_table_url }}">Tabulka velikostí</a>{% endif %}
        {% if section.settings.stretch_note != blank %}
          <span class="fca-tip">
            <button type="button" class="fca-tip__btn" aria-label="Více o velikostech">?</button>
            <span class="fca-tip__pop" role="tooltip">{{ section.settings.stretch_note }}</span>
          </span>
        {% endif %}
      </p>
      <a class="button button--primary fca-sizecta" href="#">Zobrazit produkt</a>
      <button type="button" class="fca-restart" data-fca-restart>Začít znovu</button>
    </div>
  </div>
</div>

<style>
  .fca-modal{ position:fixed; inset:0; z-index:99999; display:none; }
  .fca-modal [hidden]{ display:none !important; }
  .fca-recap{ font-size:12.5px; opacity:.62; margin:0 0 10px; line-height:1.5; }
  .fca-sizefeel{ font-size:14px; color:#a0304e; font-weight:600; margin:0 0 14px; }
  .fca-sizealts{ display:flex; flex-wrap:wrap; gap:8px; justify-content:center; margin:0 0 16px; }
  .fca-alt{ background:#f7f6f6; color:#393939; border-radius:999px; padding:7px 14px; font-size:13px; }
  .fca-alt b{ color:#a0304e; }
  .fca-sizenote{ display:flex; flex-wrap:wrap; align-items:center; justify-content:center; gap:6px 10px; font-size:12.5px; opacity:.85; line-height:1.5; margin:0 0 16px; }
  .fca-tablelink{ color:#a0304e; font-weight:600; text-decoration:underline; }
  .fca-tip{ position:relative; display:inline-flex; }
  .fca-tip__btn{ width:20px; height:20px; border-radius:50%; border:1.4px solid #a0304e; color:#a0304e; background:#fff; font-size:12px; font-weight:700; line-height:1; cursor:pointer; display:grid; place-items:center; padding:0; }
  .fca-tip__pop{ position:absolute; bottom:calc(100% + 8px); right:-6px; width:min(280px,78vw); background:#393939; color:#fff; border-radius:10px; padding:10px 12px; font-size:12px; line-height:1.5; text-align:left; opacity:0; visibility:hidden; transition:opacity .15s ease; z-index:5; pointer-events:none; }
  .fca-tip__pop::after{ content:""; position:absolute; top:100%; right:10px; border:6px solid transparent; border-top-color:#393939; }
  .fca-tip__btn:hover + .fca-tip__pop,
  .fca-tip__btn:focus + .fca-tip__pop{ opacity:1; visibility:visible; }
  .fca-modal.is-open{ display:block; }
  .fca-overlay{ position:absolute; inset:0; background:rgba(57,57,57,.55); animation:fcaFade .2s ease; }
  .fca-dialog{ position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); width:min(520px,92vw); max-height:90vh; overflow:auto; background:#fff; border-radius:22px; padding:32px 28px; box-shadow:0 24px 64px rgba(0,0,0,.28); animation:fcaPop .25s ease; }
  @keyframes fcaFade{ from{opacity:0} to{opacity:1} }
  @keyframes fcaPop{ from{opacity:0; transform:translate(-50%,-46%) scale(.97)} to{opacity:1; transform:translate(-50%,-50%) scale(1)} }
  .fca-close{ position:absolute; top:14px; right:16px; border:0; background:transparent; font-size:28px; line-height:1; color:#393939; cursor:pointer; opacity:.55; }
  .fca-close:hover{ opacity:1; }
  .fca-head h2{ margin:0 0 6px; font-size:clamp(22px,3vw,28px); color:#393939; }
  .fca-head .fca-intro{ margin:0 0 18px; opacity:.75; font-size:15px; }
  .fca-dots{ display:flex; gap:6px; margin-bottom:22px; }
  .fca-dot{ width:26px; height:4px; border-radius:999px; background:#efe1e5; transition:background .2s ease; }
  .fca-dot.is-on{ background:#a0304e; }
  .fca-q{ font-size:18px; margin:0 0 8px; color:#393939; }
  .fca-hint{ font-size:13.5px; opacity:.7; margin:0 0 16px; }
  .fca-opts, .fca-entry{ display:flex; flex-direction:column; gap:10px; }
  .fca-opt{ text-align:left; border:0; background:#ffe2e3; color:#393939; border-radius:14px; padding:16px 18px; font-size:15.5px; font-weight:500; cursor:pointer; transition:background .15s ease, color .15s ease, transform .1s ease; }
  .fca-opt:hover{ background:#a0304e; color:#fff; }
  .fca-opt.is-sel{ background:#a0304e; color:#fff; transform:scale(.99); }
  .fca-opt--big{ display:flex; flex-direction:column; gap:3px; padding:18px; }
  .fca-opt--big strong{ font-size:16.5px; }
  .fca-opt--big span{ font-size:13px; opacity:.75; }
  .fca-opt--big:hover span{ opacity:.9; }
  .fca-result, .fca-sizeresult{ text-align:center; }
  .fca-badge{ display:inline-block; background:#ffe2e3; color:#a0304e; font-size:12px; font-weight:600; padding:5px 12px; border-radius:999px; margin-bottom:10px; }
  .fca-result h3{ margin:0 0 14px; font-size:clamp(22px,3vw,28px); color:#393939; }
  .fca-reasons{ list-style:none; margin:0 auto 14px; padding:0; display:inline-flex; flex-direction:column; gap:10px; text-align:left; }
  .fca-reasons li{ position:relative; padding-left:28px; font-size:15px; color:#393939; }
  .fca-reasons li::before{ content:"✓"; position:absolute; left:0; color:#a0304e; font-weight:700; }
  .fca-tagline{ font-size:14px; opacity:.78; margin:0 0 16px; }
  .fca-price{ font-size:22px; font-weight:700; color:#393939; margin-bottom:14px; }
  .fca-result .button, .fca-sizeresult .button{ width:100%; }
  .fca-next{ display:block; width:100%; margin:10px 0 0; border:1.5px solid #a0304e; background:#fff; color:#a0304e; border-radius:var(--buttons-radius,10px); padding:12px 18px; font-size:14.5px; font-weight:600; cursor:pointer; transition:background .15s ease,color .15s ease; }
  .fca-next:hover{ background:#a0304e; color:#fff; }
  .fca-other{ display:block; margin:12px auto 0; border:0; background:transparent; color:#a0304e; font-weight:600; cursor:pointer; font-size:14px; }
  .fca-more{ display:inline-block; margin-top:12px; font-size:13px; color:#393939; opacity:.7; }
  .fca-restart{ display:block; margin:16px auto 0; border:0; background:transparent; color:#9a9a9a; font-size:13px; cursor:pointer; text-decoration:underline; }
  .fca-input{ display:flex; align-items:center; gap:10px; background:#f7f6f6; border-radius:14px; padding:6px 16px 6px 6px; margin-bottom:14px; }
  .fca-input input{ flex:1; border:0; background:#fff; border-radius:10px; padding:13px 14px; font-size:17px; color:#393939; }
  .fca-input input:focus{ outline:2px solid #a0304e; }
  .fca-input span{ font-weight:600; color:#393939; }
  .fca-calc[disabled]{ opacity:.45; cursor:not-allowed; }
  .fca-sizeletter{ font-size:56px; font-weight:800; color:#a0304e; line-height:1; margin:6px 0 8px; }
  .fca-sizematch{ font-size:15px; color:#393939; margin:0 0 14px; }
  @media (max-width:600px){ .fca-dialog{ padding:26px 20px; border-radius:18px; } }
</style>

<script>
(function(){
  var root = document.getElementById('fitka-advisor');
  if(!root || root.dataset.fcaInit) return;
  root.dataset.fcaInit = '1';

  var SIZES = JSON.parse(root.dataset.sizes);
  var PRODUCT_URLS = { tanga: {{ tp.url | default: '/products/brazilky-fitka' | json }}, brief: {{ bp.url | default: '/products/brief-fitka' | json }} };
  var tiebreak = root.dataset.tiebreak || 'brief';

  var el = {
    entry: root.querySelector('.fca-entry'),
    stepsWrap: root.querySelector('.fca-steps'),
    steps: [].slice.call(root.querySelectorAll('.fca-step')),
    dotsWrap: root.querySelector('.fca-dots'),
    results: { tanga: root.querySelector('[data-result="tanga"]'), brief: root.querySelector('[data-result="brief"]') },
    sizecut: root.querySelector('.fca-sizecut'),
    measure: root.querySelector('.fca-measure'),
    feel: root.querySelector('.fca-feel'),
    input: root.querySelector('.fca-input input'),
    calc: root.querySelector('.fca-calc'),
    sres: root.querySelector('.fca-sizeresult'),
    sletter: root.querySelector('.fca-sizeletter'),
    smatch: root.querySelector('.fca-sizematch'),
    sfeel: root.querySelector('.fca-sizefeel'),
    salts: root.querySelector('.fca-sizealts'),
    scta: root.querySelector('.fca-sizecta')
  };

  var answers = [], answerLabels = [], current = 0, sizeCut = null, sizePref = null;

  el.steps.forEach(function(){ var d=document.createElement('span'); d.className='fca-dot'; el.dotsWrap.appendChild(d); });
  var dots = [].slice.call(el.dotsWrap.children);

  function hideAll(){
    el.entry.hidden = true;
    el.stepsWrap.hidden = true;
    el.dotsWrap.hidden = true;
    el.sizecut.hidden = true;
    el.measure.hidden = true;
    el.feel.hidden = true;
    el.sres.hidden = true;
    el.results.tanga.hidden = true;
    el.results.brief.hidden = true;
  }
  function showEntry(){
    hideAll(); answers=[]; answerLabels=[]; current=0; sizeCut=null; sizePref=null;
    el.input.value=''; el.calc.disabled=true;
    [].forEach.call(root.querySelectorAll('.fca-opt.is-sel'), function(b){ b.classList.remove('is-sel'); });
    el.entry.hidden = false;
  }
  function showStep(n){
    hideAll(); el.stepsWrap.hidden=false; el.dotsWrap.hidden=false;
    el.steps.forEach(function(s,i){ s.hidden = i!==n; });
    dots.forEach(function(d,i){ d.classList.toggle('is-on', i<=n); });
  }
  function showCutResult(){
    var t=answers.filter(function(a){return a==='tanga';}).length;
    var b=answers.filter(function(a){return a==='brief';}).length;
    var win = t>b ? 'tanga' : (b>t ? 'brief' : tiebreak);
    hideAll(); el.results[win].hidden = false;
    var rc = el.results[win].querySelector('.fca-recap');
    if(rc) rc.textContent = answerLabels.length ? 'Tvoje odpovědi: ' + answerLabels.join(' · ') : '';
  }
  function showSizeCut(){ hideAll(); el.sizecut.hidden=false; }
  function showMeasure(){ hideAll(); el.measure.hidden=false; el.input.focus(); }
  function showFeel(){ hideAll(); el.feel.hidden=false; }

  function calcSize(cut, x, pref){
    var table = SIZES[cut];
    var order = ['S','M','L'];
    var target = pref==='tight' ? 0.72 : (pref==='loose' ? 0.28 : 0.5);
    var scores = {}, pos = {}, total = 0;
    order.forEach(function(k){
      var min=table[k][0], max=table[k][1];
      var s = 0;
      if(x>=min && x<=max){
        var p = (x-min)/(max-min); // 0 = u klidového stavu (volnější), 1 = u nataženého (pevnější)
        pos[k] = p;
        s = Math.max(0.1, 1 - Math.abs(p-target));
      }
      scores[k]=s; total+=s;
    });
    if(total===0){
      var best=null, dist=1e9;
      order.forEach(function(k){
        var d = x<table[k][0] ? table[k][0]-x : x-table[k][1];
        if(d<dist){ dist=d; best=k; }
      });
      return { best:best, pct:null, all:null, feel:null, outside:true };
    }
    var best=order[0];
    order.forEach(function(k){ if(scores[k]>scores[best]) best=k; });
    function feelOf(p){ return p < 0.35 ? 'volnější' : (p < 0.65 ? 'vyvážený' : 'pevnější'); }
    var alts = [];
    order.forEach(function(k){
      if(k!==best && scores[k]>0) alts.push({ size:k, feel:feelOf(pos[k]) });
    });
    var pct = Math.round(70 + 30*scores[best]); // v tabulce sedí vždy => 70–100 % dle blízkosti preferenci
    return { best:best, pct:pct, alts:alts, feel:feelOf(pos[best]), outside:false };
  }

  function showSizeResult(){
    var x = parseFloat(el.input.value.replace(',','.'));
    if(isNaN(x)) return;
    var r = calcSize(sizeCut, x, sizePref);
    hideAll(); el.sres.hidden=false;
    var prefWord = sizePref==='tight' ? 'pevnější' : (sizePref==='loose' ? 'volnější' : 'vyvážený');
    var cutWord = sizeCut==='tanga' ? 'Tanga' : 'Brief';
    var src = el.sres.querySelector('.fca-recap');
    if(src) src.textContent = 'Vybíráš ' + cutWord + ', tvoje míra je ' + x + ' cm a preferuješ ' + prefWord + ' pocit.';
    el.sletter.textContent = r.best;
    el.scta.href = PRODUCT_URLS[sizeCut];
    el.scta.textContent = 'Zobrazit ' + (sizeCut==='tanga'?'Tanga':'Brief');
    el.salts.innerHTML='';
    el.sfeel.textContent='';
    if(r.outside){
      el.smatch.textContent = 'Tvoje míra je mimo rozsah tabulky – nejblíž ti bude velikost ' + r.best + '. Radši nám napiš, poradíme osobně.';
    } else {
      el.smatch.textContent = 'Tvoje míra (' + x + ' cm) se shoduje s tabulkou velikostí na ' + r.pct + ' %.';
      el.sfeel.textContent = 'Ve velikosti ' + r.best + ' budeš mít ' + r.feel + ' pocit.';
      r.alts.forEach(function(a){
        var chip=document.createElement('span');
        chip.className='fca-alt';
        chip.innerHTML='Seděla by ti i <b>'+a.size+'</b> · '+a.feel+' pocit';
        el.salts.appendChild(chip);
      });
    }
  }

  // vstupní volba
  [].forEach.call(el.entry.querySelectorAll('[data-mode]'), function(b){
    b.addEventListener('click', function(){
      if(b.dataset.mode==='cut'){ answers=[]; answerLabels=[]; current=0; showStep(0); }
      else { showSizeCut(); }
    });
  });

  // kvíz střihu
  el.steps.forEach(function(step){
    [].forEach.call(step.querySelectorAll('.fca-opt'), function(btn){
      btn.addEventListener('click', function(){
        [].forEach.call(step.querySelectorAll('.fca-opt'), function(b){ b.classList.remove('is-sel'); });
        btn.classList.add('is-sel');
        answers[current] = btn.dataset.target;
        answerLabels[current] = btn.textContent.trim();
        setTimeout(function(){
          current++;
          if(current < el.steps.length) showStep(current); else showCutResult();
        }, 220);
      });
    });
  });

  // z výsledku střihu → velikost (přenese střih)
  [].forEach.call(root.querySelectorAll('[data-size-for]'), function(b){
    b.addEventListener('click', function(){ sizeCut=b.dataset.sizeFor; showMeasure(); });
  });

  // velikost: volba střihu
  [].forEach.call(el.sizecut.querySelectorAll('[data-sizecut]'), function(b){
    b.addEventListener('click', function(){ sizeCut=b.dataset.sizecut; setTimeout(showMeasure,160); });
  });

  // velikost: míra
  el.input.addEventListener('input', function(){
    var v=parseFloat(el.input.value.replace(',','.'));
    el.calc.disabled = isNaN(v) || v<40 || v>130;
  });
  el.input.addEventListener('keydown', function(e){ if(e.key==='Enter' && !el.calc.disabled) showFeel(); });
  el.calc.addEventListener('click', showFeel);

  // velikost: preferovaný pocit
  [].forEach.call(el.feel.querySelectorAll('[data-feel]'), function(b){
    b.addEventListener('click', function(){
      sizePref = b.dataset.feel;
      b.classList.add('is-sel');
      setTimeout(showSizeResult, 160);
    });
  });

  // přepnutí výsledku střihu
  [].forEach.call(root.querySelectorAll('[data-show]'), function(b){
    b.addEventListener('click', function(){
      var k=b.dataset.show;
      hideAll(); el.results[k].hidden=false;
    });
  });

  [].forEach.call(root.querySelectorAll('[data-fca-restart]'), function(b){ b.addEventListener('click', showEntry); });

  function open(){ showEntry(); root.classList.add('is-open'); root.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
  function close(){ root.classList.remove('is-open'); root.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
  window.fitkaOpenAdvisor = open;

  [].forEach.call(root.querySelectorAll('[data-fca-close]'), function(b){ b.addEventListener('click', close); });
  document.addEventListener('keydown', function(e){ if(e.key==='Escape' && root.classList.contains('is-open')) close(); });
  document.addEventListener('click', function(e){
    var trg = e.target.closest('[data-fitka-advisor], a[href$="#fitka-advisor"]');
    if(trg){ e.preventDefault(); open(); }
  });
})();
</script>

