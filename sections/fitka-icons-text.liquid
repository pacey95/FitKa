{% comment %} sections/fitka-icons-text.liquid — FitKa (inline: ikona vlevo / stacked: ikona nahoře) {% endcomment %}
{%- assign icon_size = section.settings.icon_size | default: 56 -%}
{%- assign layout = section.settings.layout | default: 'inline' -%}

<section
  class="fitka-icons fitka-icons--{{ layout }}{% if section.settings.show_dividers %} fitka-icons--divided{% endif %}"
  style="
    --icon-size: {{ icon_size }}px;
    --text-color: {{ section.settings.text_color }};
    {% if section.settings.bg_color != blank %}--bg-color: {{ section.settings.bg_color }};{% endif %}
    {% if section.settings.bg_image != blank %}--bg-image: url({{ section.settings.bg_image | image_url: width: 2400 }});{% endif %}
    --bg-image-opacity: {{ section.settings.bg_image_opacity | default: 100 | divided_by: 100.0 }};
  "
>
  <div class="fitka-icons__bg"></div>

  <div class="page-width fitka-icons__inner">
    <h2 class="visually-hidden">Proč sportovní kalhotky FitKa</h2>

    {% if section.settings.heading != blank %}
      <h2 class="fitka-icons__heading" style="color: var(--text-color, inherit)">{{ section.settings.heading }}</h2>
    {% endif %}

    <div id="icons-grid-{{ section.id }}" class="fitka-icons__grid">
      {% for block in section.blocks %}
        <div class="fitka-icons__item" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            {{ block.settings.icon | image_url: width: 256 | image_tag: class: 'fitka-icons__icon', alt: block.settings.title }}
          {% endif %}
          <div class="fitka-icons__body">
            <h3 class="fitka-icons__title" style="color: var(--text-color, inherit)">{{ block.settings.title }}</h3>
            {% if block.settings.text != blank %}
              <p class="fitka-icons__text" style="color: var(--text-color, inherit)">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <style>
    .fitka-icons{
      position:relative; padding: {{ section.settings.padding_y | default: 32 }}px 0;
      background: var(--bg-color, transparent);
    }
    .fitka-icons__bg{
      position:absolute; inset:0; z-index:0;
      background-image: var(--bg-image, none);
      background-size:cover; background-position:center;
      opacity: var(--bg-image-opacity, 1);
      pointer-events:none;
    }
    .fitka-icons__inner{ position:relative; z-index:1; }
    .fitka-icons__heading{ text-align:center; margin-bottom:clamp(12px, 3.5vw, 20px); }

    .fitka-icons__grid{
      display:grid; gap:clamp(12px, 3vw, 20px);
      grid-template-columns: repeat(4, 1fr);
    }
    @media (max-width: 1024px){
      .fitka-icons__grid{ grid-template-columns: repeat(2, 1fr); }
    }

    .fitka-icons__item{ display:flex; gap:14px; padding:clamp(6px, 2vw, 14px); background:transparent; }

    /* INLINE: ikona vlevo, text vpravo */
    .fitka-icons--inline .fitka-icons__item{ flex-direction:row; align-items:center; text-align:left; }
    /* STACKED: ikona nahoře, na střed */
    .fitka-icons--stacked .fitka-icons__item{ flex-direction:column; align-items:center; text-align:center; }

    .fitka-icons__icon{
      flex:0 0 auto; object-fit:contain; transition:transform .18s ease-out;
      width: clamp(36px, 9vw, var(--icon-size));
      height: clamp(36px, 9vw, var(--icon-size));
      {% if section.settings.invert_icons %}filter: invert(1);{% endif %}
    }
    .fitka-icons--stacked .fitka-icons__icon{ margin:0 auto clamp(6px, 1.8vw, 10px); }
    .fitka-icons__item:hover .fitka-icons__icon,
    .fitka-icons__item:focus-within .fitka-icons__icon{ transform: scale(1.08); }

    .fitka-icons__body{ min-width:0; }
    .fitka-icons__title{ margin:0 0 4px; font-size:clamp(14px, 2.4vw, 17px); line-height:1.2; font-weight:600; }
    .fitka-icons__text{ margin:0; opacity:.8; font-size:clamp(12px, 2.2vw, 14px); line-height:1.45; }

    /* Svislé oddělovače mezi položkami – jen na desktopu (4 v řadě) */
    @media (min-width: 1025px){
      .fitka-icons--divided .fitka-icons__item:not(:first-child){
        border-left:1px solid #e8e0e2; padding-left:28px;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Ikony s textem",
  "settings": [
    { "type": "text", "id": "heading", "label": "Nadpis", "default": "Proč FitKa?" },
    {
      "type": "select", "id": "layout", "label": "Rozložení", "default": "inline",
      "options": [
        { "value": "inline", "label": "Ikona vlevo od textu" },
        { "value": "stacked", "label": "Ikona nad textem (na střed)" }
      ]
    },
    { "type": "checkbox", "id": "show_dividers", "default": true, "label": "Svislé oddělovače mezi položkami (desktop)" },
    { "type": "range", "id": "icon_size", "min": 24, "max": 160, "step": 4, "default": 56, "label": "Max. velikost ikon (px)" },
    { "type": "checkbox", "id": "invert_icons", "default": false, "label": "Invertovat barvy ikon (pro tmavé pozadí)" },

    { "type": "color", "id": "bg_color", "label": "Barva pozadí sekce" },
    { "type": "image_picker", "id": "bg_image", "label": "Obrázek pozadí sekce (volitelné)" },
    { "type": "range", "id": "bg_image_opacity", "min": 0, "max": 100, "step": 5, "default": 100, "label": "Krytí obrázku pozadí (%)" },
    { "type": "color", "id": "text_color", "label": "Barva textu" },
    { "type": "range", "id": "padding_y", "min": 0, "max": 80, "step": 2, "default": 32, "label": "Svislé odsazení sekce (px)" }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Ikona",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Ikona (PNG/SVG)" },
        { "type": "text", "id": "title", "label": "Titulek", "default": "Antibakteriální" },
        { "type": "text", "id": "text", "label": "Popis", "default": "Materiály s antibakteriální úpravou pro celodenní komfort." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Ikony s textem", "category": "FitKa" }]
}
{% endschema %}
